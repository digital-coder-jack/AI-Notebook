# =====================================================================
#  Study Sphere AI  -  environment variables
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit the real .env file (it is git-ignored).
# =====================================================================

# --- Groq AI (required for all AI features) -------------------------
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the default model.
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Telegram bot (required only if you run the bot) ----------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional but recommended: a secret to verify webhook calls.
# WEBHOOK_SECRET=some_long_random_string

# --- Web app security (set a strong, stable secret in production) ----
# If unset, a random secret is generated per process (tokens won't
# survive restarts). Set this in production.
JWT_SECRET=change_me_to_a_long_random_secret
# Token lifetime in seconds (default 7 days).
# JWT_TTL_SECONDS=604800

# --- Optional tuning -------------------------------------------------
# DB_PATH=study_sphere.db
# RATE_LIMIT=120
# RATE_WINDOW=60
