# ============================================================
# Study Sphere Backend - Environment Variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env file or expose these to clients.
# ============================================================

# Server
PORT=8080
NODE_ENV=development

# JWT secret used to sign auth tokens (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret_value
JWT_EXPIRES_IN=7d

# Comma separated list of allowed CORS origins (frontend + local dev)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ============================================================
# AI PROVIDER KEYS  (SERVER-SIDE ONLY - never sent to clients)
# These map to the internal models behind the "Lite" and "Pro"
# plans. Clients never see provider names or keys.
# ============================================================

# Provider used for the "Study Sphere Lite" plan models
LITE_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
LITE_PROVIDER_API_KEY=your_lite_provider_key_here

# Provider used for the "Study Sphere Pro" plan models
PRO_PROVIDER_BASE_URL=https://api.openai.com/v1
PRO_PROVIDER_API_KEY=your_pro_provider_key_here
